    function calculate(element) {
        const card = element.closest('.card');
        const getVal = (selector) => parseFloat(card.querySelector(selector).value);
        const id_mm = getVal('.id-mm');
        const length_m = getVal('.length-m');
        const spacing_m = getVal('.spacing-m');
        const discharge_lph = getVal('.discharge-lph');
        const pressure_m = getVal('.pressure-m');
        
        const drippers_per_plant = getVal('.drippers-per-plant') || 1; 

        const vel_unit = card.querySelector('.velocity-unit').value;
        const flow_unit = card.querySelector('.flow-unit').value;
        
        const C = getVal('.roughness') || 140; 
        const F = getVal('.outlet-factor') || 0.4;
        const K = 1.21e10; 

        if (!id_mm || !length_m || !spacing_m || !discharge_lph) return;

        const num_positions = length_m / spacing_m;
        const total_drippers_count = num_positions * drippers_per_plant;
        const total_q_lph = total_drippers_count * discharge_lph;
        
        const q_lps = total_q_lph / 3600.0;
        const q_m3s = q_lps / 1000.0;

        let display_q = 0;
        let flow_suffix = "";
        switch(flow_unit) {
            case "m3hr": display_q = total_q_lph / 1000.0; flow_suffix = " m³/hr"; break;
            case "lps": display_q = total_q_lph / 3600.0; flow_suffix = " lps"; break;
            case "lpm": display_q = total_q_lph / 60.0; flow_suffix = " lpm"; break;
            case "gpm": display_q = total_q_lph / 227.1247; flow_suffix = " gpm"; break;
            default: display_q = total_q_lph; flow_suffix = " lph";
        }

        const id_m = id_mm / 1000.0;
        const area_m2 = Math.PI * Math.pow((id_m / 2.0), 2);
        let velocity = q_m3s / area_m2;
        let vel_str = (vel_unit === "ft/s") ? (velocity * 3.28084).toFixed(2) + " ft/s" : velocity.toFixed(2) + " m/s";

        let head_loss = 0;
        if (id_mm > 0 && C > 0) {
            const term_q = Math.pow((q_lps / C), 1.852);
            const term_d = Math.pow(id_mm, -4.87);
            head_loss = F * length_m * K * term_q * term_d;
        }

        const total_pressure = pressure_m + head_loss;

        card.querySelector('.res-drippers').innerText = total_drippers_count.toFixed(0);
        card.querySelector('.res-discharge').innerText = display_q.toFixed(2) + flow_suffix;
        card.querySelector('.res-velocity').innerText = vel_str;
        card.querySelector('.res-headloss').innerText = head_loss.toFixed(2) + " m";
        card.querySelector('.res-pressure').innerText = total_pressure.toFixed(2) + " m";
        
        const subInput = document.getElementById('lat_inlet_press');
        if(subInput) {
            subInput.value = total_pressure.toFixed(2);
            calculateSubmain(); 
        }
        
        calculateUniformity(total_pressure, pressure_m);
    }

