    // --- CARD 10 LOGIC (Darcy-Weisbach) ---
    function calculateDarcy() {
        const id_mm = parseFloat(document.getElementById('dw_id').value) || 0;
        const length = parseFloat(document.getElementById('dw_length').value) || 0;
        const flowVal = parseFloat(document.getElementById('dw_flow').value) || 0;
        const unit = document.getElementById('dw_flow_unit').value;
        const f = parseFloat(document.getElementById('dw_f').value) || 0.02;
        const g = 9.81;

        if (id_mm <= 0) return;

        let q_m3s = 0;
        if (unit === 'lps') q_m3s = flowVal / 1000.0;
        else if (unit === 'lpm') q_m3s = flowVal / 60000.0;
        else if (unit === 'm3h') q_m3s = flowVal / 3600.0;

        const id_m = id_mm / 1000.0;
        const area = Math.PI * Math.pow((id_m / 2.0), 2);
        const v = (area > 0) ? (q_m3s / area) : 0;

        let hf = 0;
        if (id_m > 0) {
            hf = f * (length / id_m) * (Math.pow(v, 2) / (2 * g));
        }

        document.getElementById('dw_velocity').innerText = v.toFixed(2) + " m/s";
        document.getElementById('dw_head_loss').innerText = hf.toFixed(3) + " m";
    }

    // --- CARD 11 LOGIC (Reynolds) ---
    function updateFluids() {
        const temp = parseFloat(document.getElementById('re_temp').value) || 20;
        
        const T = temp;
        const rho = 1000 * (1 - (T + 288.9416) / (508929.2 * (T + 68.12963)) * Math.pow(T - 3.9863, 2));
        
        const kin_visc_m2s = (1.78 / (1 + 0.0337 * T + 0.000221 * T * T)) * 1e-6;
        const mu_Pas = kin_visc_m2s * rho;
        const mu_cP = mu_Pas * 1000;

        document.getElementById('re_density').value = rho.toFixed(1);
        document.getElementById('re_visc').value = mu_cP.toFixed(3);
        
        calculateReynolds();
    }

    function calculateReynolds() {
        const id_mm = parseFloat(document.getElementById('re_id').value) || 0;
        const flowVal = parseFloat(document.getElementById('re_flow').value) || 0;
        const unit = document.getElementById('re_flow_unit').value;
        
        const rho = parseFloat(document.getElementById('re_density').value) || 998.2;
        const mu_cP = parseFloat(document.getElementById('re_visc').value) || 1.002;

        if (id_mm <= 0) return;

        let q_m3s = 0;
        if (unit === 'lps') q_m3s = flowVal / 1000.0;
        else if (unit === 'lpm') q_m3s = flowVal / 60000.0;
        else if (unit === 'm3h') q_m3s = flowVal / 3600.0;

        const id_m = id_mm / 1000.0;
        const area = Math.PI * Math.pow((id_m / 2.0), 2);
        const v = (area > 0) ? (q_m3s / area) : 0;
        
        const mu_Pas = mu_cP * 0.001;
        const Re = (rho * v * id_m) / mu_Pas;

        let type = "-";
        let color = "#333";
        
        if (Re < 2000) {
            type = "Laminar";
            color = "#28a745";
        } else if (Re >= 2000 && Re <= 4000) {
            type = "Transition";
            color = "#ffc107";
        } else {
            type = "Turbulent";
            color = "#dc3545";
        }

        document.getElementById('re_number').innerText = Re.toFixed(0);
        const typeEl = document.getElementById('re_type');
        typeEl.innerText = type;
        typeEl.style.color = color;
    }

