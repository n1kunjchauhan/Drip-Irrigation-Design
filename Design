    function calculatePrecipitation() {
        const bedS = parseFloat(document.getElementById('bed_spacing').value) || 1;
        const dripS = parseFloat(document.getElementById('dripper_spacing').value) || 1;
        const latN = parseFloat(document.getElementById('laterals_per_bed').value) || 1;
