    function calcBox19() {
        const C = parseFloat(document.getElementById('v19_roughness').value) || 150;
        const F = parseFloat(document.getElementById('v19_outlet_factor').value) || 1.0;
        const fittingVal = parseInt(document.getElementById('v19_fitting_side').value) || 1;

        const pipeExtraPct = (parseFloat(document.getElementById('v19_pipe_extra_pct').value) || 0) / 100;
        const fitExtraPct  = (parseFloat(document.getElementById('v19_fit_extra_pct').value)  || 0) / 100;
        const latExtraPct  = (parseFloat(document.getElementById('v19_lat_extra_pct').value)  || 0) / 100;

        // Box 3 values (hidden but used)
        const bedS = parseFloat(document.getElementById('bed_spacing').value) || 1;
        const latN = parseFloat(document.getElementById('laterals_per_bed').value) || 1;
        const dripS = parseFloat(document.getElementById('dripper_spacing').value) || 1;
        const dripQ = parseFloat(document.getElementById('dripper_discharge').value) || 0; // LPH

        const avgLatSpacing = bedS / latN; // m

        // Summary maps
        const pipeSummary = {}; // key => total net length (raw)
        let totalFittingSets = 0;
        let totalValveArea = 0;

        const rows = document.querySelectorAll('#v19_tbody tr');
        rows.forEach(tr => {
            const idx = tr.dataset.valveIdx;
            if(!idx) return;

            const areaEl = document.getElementById('v19_area_' + idx);
            const typeEl = document.getElementById('v19_type_' + idx);
            const classEl = document.getElementById('v19_class_' + idx);
            const sizeEl = document.getElementById('v19_size_' + idx);
            const idInput = document.getElementById('v19_id_' + idx);
            const lenEl = document.getElementById('v19_len_' + idx);

            if(!areaEl || !typeEl || !classEl || !sizeEl || !lenEl) return;

            const valveArea = parseFloat(areaEl.value) || 0;
            const pType = typeEl.value;
            const pClass = classEl.value;
            const pSize = sizeEl.value;
            const pLen = parseFloat(lenEl.value) || 0;

            // Get ID — prefer user-edited input, fallback to dropdown lookup
            let id_mm = 0;
            const idInputVal = idInput ? parseFloat(idInput.value) : NaN;
            if(!isNaN(idInputVal) && idInputVal > 0) {
                id_mm = idInputVal;
            } else if(pSize !== 'custom') {
                id_mm = getV19ID(pType, pClass, pSize) || 0;
                // Also update the input box if empty
                if(idInput && (!idInput.value || idInput.value === '')) {
                    idInput.value = id_mm > 0 ? parseFloat(id_mm.toFixed(1)) : '';
                }
            }

            // Valve Flow (m³/hr)
            let valveFlow_m3h = 0;
            if(avgLatSpacing > 0 && dripS > 0) {
                const numDrippers = valveArea / (avgLatSpacing * dripS);
                const flowLPH = numDrippers * dripQ;
                valveFlow_m3h = flowLPH / 1000.0;
            }

            // Hydraulics
            let vel = 0, hf = 0;
            if(id_mm > 0 && valveFlow_m3h > 0) {
                const res = calcHydraulics(id_mm, pLen, valveFlow_m3h, 'm3h', C, F);
                vel = res.v;
                hf = res.hf;
            }

            // Fitting Sets = (pLen / avgLatSpacing) * fittingVal
            let fittingSets = 0;
            if(avgLatSpacing > 0) {
                fittingSets = (pLen / avgLatSpacing) * fittingVal;
            }

            // Update cells
            document.getElementById('v19_flow_' + idx).innerText = valveFlow_m3h.toFixed(3);

            const velCell = document.getElementById('v19_vel_' + idx);
            velCell.innerText = vel.toFixed(2);
            velCell.className = 'out-cell' + (vel > 2.5 ? ' warn' : '');

            const hlCell = document.getElementById('v19_hl_' + idx);
            hlCell.innerText = hf.toFixed(3);

            document.getElementById('v19_fs_' + idx).innerText = fittingSets.toFixed(1);

            // Summary aggregation — build key for summary
            if(pSize !== 'custom' && pLen > 0) {
                let clsLabel = pClass;
                if(pClass==='4kg') clsLabel='4 kg/cm²';
                else if(pClass==='6kg') clsLabel='6 kg/cm²';
                else if(pClass==='pn4') clsLabel='PN 4';
                else if(pClass==='pn6') clsLabel='PN 6';
                else if(pClass==='sch40') clsLabel='Sch 40';
                else if(pClass==='sch80') clsLabel='Sch 80';
                let typeLabel = pType === 'agri' ? 'Agri PVC' : pType === 'upvc' ? 'uPVC' : 'HDPE';
                const key = `${pSize} mm (${clsLabel}) – ${typeLabel}`;
                pipeSummary[key] = (pipeSummary[key] || 0) + pLen;
            }
            totalFittingSets += fittingSets;
            totalValveArea += valveArea;
        });

        // Apply extra material % to fittings
        const fittingsWithExtra = totalFittingSets * (1 + fitExtraPct);

        const pipeSumEl = document.getElementById('v19_pipe_summary');
        const fitSumEl = document.getElementById('v19_fitting_summary');
        const areaLatEl = document.getElementById('v19_area_lateral_summary');

        if(Object.keys(pipeSummary).length === 0) {
            pipeSumEl.innerHTML = '<span style="color:#aaa;font-size:0.82rem;">No data</span>';
        } else {
            pipeSumEl.innerHTML = Object.entries(pipeSummary)
                .sort((a,b) => a[0].localeCompare(b[0]))
                .map(([k, v]) => {
                    const withExtra = v * (1 + pipeExtraPct);
                    const rounded = Math.ceil(withExtra / 6) * 6;
                    const pipes = rounded / 6;
                    return `<div class="summary-item">
                        <span class="s-key">${k}</span>
                        <span class="s-val">${rounded.toFixed(0)} m <span style="font-size:0.72rem;color:#555;">(${pipes.toFixed(0)} pipes × 6m)</span></span>
                    </div>`;
                })
                .join('');
        }

        fitSumEl.innerHTML = `<div class="summary-item"><span class="s-key">Total Fitting Sets (net)</span><span class="s-val">${totalFittingSets.toFixed(1)} nos</span></div>
        <div class="summary-item"><span class="s-key">With Extra ${(fitExtraPct*100).toFixed(1)}%</span><span class="s-val" style="color:#e65100;">${fittingsWithExtra.toFixed(1)} nos</span></div>`;

        const totalLatLen = avgLatSpacing > 0 ? (totalValveArea / avgLatSpacing) : 0;
        const latWithExtra = totalLatLen * (1 + latExtraPct);
        const latRounded = Math.ceil(latWithExtra / 25) * 25;

        areaLatEl.innerHTML = `
            <div class="summary-item"><span class="s-key">Total Valve Area</span><span class="s-val">${totalValveArea.toFixed(1)} m²</span></div>
            <div class="summary-item"><span class="s-key">Total Lateral Length (net)</span><span class="s-val">${totalLatLen.toFixed(1)} m</span></div>
            <div class="summary-item"><span class="s-key">With Extra ${(latExtraPct*100).toFixed(1)}% → rounded ×25m</span><span class="s-val" style="color:#e65100;">${latRounded.toFixed(0)} m</span></div>
        `;
    }

    // --- JS MASONRY LAYOUT ---
    function layoutCards() {
        const container = document.querySelector('.app-container');
        const cards = document.querySelectorAll('.card');
        const containerWidth = container.offsetWidth;
        
        if(window.innerWidth <= 768) {
            container.style.height = 'auto';
            return;
        }

        // Card 19 is wide (780px), others are 350px
        const gap = 20;
        const normalWidth = 350;
        const wideWidth = 780;

        // Two-pass: first place normal cards in columns, then wide cards at bottom
        let colCount = Math.floor((containerWidth + gap) / (normalWidth + gap));
        colCount = Math.max(1, colCount);

        const gridWidth = colCount * normalWidth + (colCount - 1) * gap;
        const startX = (containerWidth - gridWidth) / 2;

        const colHeights = new Array(colCount).fill(0);

        cards.forEach((card) => {
            const isWide = card.id === 'card-19';

            if(!isWide) {
                card.style.width = normalWidth + 'px';
                const colIndex = getShortestCol(colHeights);
                card.style.top = colHeights[colIndex] + 'px';
                card.style.left = startX + colIndex * (normalWidth + gap) + 'px';
                colHeights[colIndex] += card.offsetHeight + gap;
            }
        });

        // Place wide card (card-19) below all columns — full width
        const maxColH = Math.max(...colHeights);
        const wideCard = document.getElementById('card-19');
        if(wideCard) {
            const actualWide = containerWidth - 40;
            wideCard.style.width = actualWide + 'px';
            wideCard.style.top = maxColH + 'px';
            wideCard.style.left = '20px';
        }

        const wideH = wideCard ? wideCard.offsetHeight : 0;
        container.style.height = (maxColH + wideH + gap) + 'px';
    }

    function getShortestCol(colHeights) {
        let minH = colHeights[0], minIdx = 0;
        colHeights.forEach((h, i) => { if(h < minH) { minH = h; minIdx = i; } });
        return minIdx;
    }

    window.addEventListener('resize', layoutCards);

    window.onload = function() {
        updateInterface();
        calculateSystemFlow();
        calculateAvailableFlow();
        calculateRequiredHP();
        
        const cards = document.querySelectorAll('.card');
        cards.forEach(card => {
            if (card.id.startsWith('card-1') || card.id.startsWith('card-2') || card.id.startsWith('card-3') || card.id.startsWith('card-4') || card.id.startsWith('card-5') || card.id.startsWith('card-7') || card.id.startsWith('card-8') || card.id.startsWith('card-9') || card.id.startsWith('card-10') || card.id.startsWith('card-15') || card.id.startsWith('card-16') || card.id.startsWith('card-17')) return; 
            const select = card.querySelector('.nominal-dia');
            if(select) updateID(select);
        });

        updateSubmainOptions();
        updateMainOptions();
        
        calculateDarcy();
        updateFluids();
        calcVelocity();
        calculateTotalHead();
        
        const latCard = document.getElementById('card-6');
        if(latCard) calculate(latCard.querySelector('.id-mm'));
        
        initPeakData();
        calculateFogging();

        // Init Box 19 with 4 default valves
        addValveRow();
        addValveRow();
        addValveRow();
        addValveRow();
        
        setTimeout(layoutCards, 200);
    };
</script>
</body>
</html>
