    function calcHydraulics(id_mm, length, flowVal, unit, C, F) {
        if (id_mm <= 0) return {v:0, hf:0};
        
        let q_lps = 0;
        if (unit === 'lps') q_lps = flowVal;
        if (unit === 'lpm') q_lps = flowVal / 60.0;
        if (unit === 'm3h') q_lps = flowVal / 3.6;

        const q_m3s = q_lps / 1000.0;
        const id_m = id_mm / 1000.0;
        const area = Math.PI * Math.pow((id_m / 2.0), 2);
        const v = (area > 0) ? (q_m3s / area) : 0;

        const K = 1.21e10;
        const term_q = Math.pow((q_lps / C), 1.852);
        const term_d = Math.pow(id_mm, -4.87);
        const hf = F * length * K * term_q * term_d;
        
        return {v: v, hf: hf};
    }

