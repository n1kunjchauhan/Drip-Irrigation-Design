        document.getElementById('pr_drip_spacing').value = dripS;
        document.getElementById('pr_lat_per_bed').value = latN;
        document.getElementById('pr_discharge').value = q;
        
        // Precipitation Rate
        let pr = 0;
        if(bedS > 0 && dripS > 0) {
            pr = (q * latN) / (bedS * dripS); // mm/hr
            document.getElementById('pr_result').innerText = pr.toFixed(2);
        } else {
            document.getElementById('pr_result').innerText = "0.00";
        }
        
        // Time Calculation
        const peakReq = parseFloat(document.getElementById('peak_water_req').value) || 0;
        const unit = document.getElementById('time_unit').value;
        
        if (pr > 0 && peakReq > 0) {
            const timeHrs = peakReq / pr;
            
            if (unit === 'min') {
                document.getElementById('irrig_time').innerText = Math.round(timeHrs * 60) + " min";
            } else if (unit === 'hr') {
                document.getElementById('irrig_time').innerText = timeHrs.toFixed(2) + " hr";
            } else {
                const hrs = Math.floor(timeHrs);
                const mins = Math.round((timeHrs - hrs) * 60);
                document.getElementById('irrig_time').innerText = `${hrs} hr ${mins} min`;
            }
        } else {
            document.getElementById('irrig_time').innerText = "-";
        }
    }

