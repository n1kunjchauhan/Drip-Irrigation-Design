<script>
    // --- CONVERTER LOGIC ---
    
    // Pressure
    function convertPressure(source) {
        let val = 0;
        if(source === 'm') val = parseFloat(document.getElementById('conv_p_m').value);
        else if(source === 'bar') val = parseFloat(document.getElementById('conv_p_bar').value) / 0.0980665;
        else if(source === 'kg') val = parseFloat(document.getElementById('conv_p_kg').value) / 0.1; 
        else if(source === 'psi') val = parseFloat(document.getElementById('conv_p_psi').value) / 1.42233;
        
        if(isNaN(val)) return;

        const m = val;
        const bar = val * 0.0980665;
        const kg = val * 0.1;
        const psi = val * 1.42233;
        
        if(source !== 'm') document.getElementById('conv_p_m').value = parseFloat(m.toFixed(3));
        if(source !== 'bar') document.getElementById('conv_p_bar').value = parseFloat(bar.toFixed(3));
        if(source !== 'kg') document.getElementById('conv_p_kg').value = parseFloat(kg.toFixed(3));
        if(source !== 'psi') document.getElementById('conv_p_psi').value = parseFloat(psi.toFixed(3));
    }

    // Flow
    function convertFlow(source) {
        let val_m3h = 0;
        if(source === 'm3h') val_m3h = parseFloat(document.getElementById('conv_f_m3h').value);
        else if(source === 'lps') val_m3h = parseFloat(document.getElementById('conv_f_lps').value) * 3.6;
        else if(source === 'lpm') val_m3h = parseFloat(document.getElementById('conv_f_lpm').value) * 0.06;
        else if(source === 'gpm') val_m3h = parseFloat(document.getElementById('conv_f_gpm').value) / 4.40287;
        
        if(isNaN(val_m3h)) return;

        const m3h = val_m3h;
        const lps = val_m3h / 3.6;
        const lpm = val_m3h / 0.06;
        const gpm = val_m3h * 4.40287;
        
        if(source !== 'm3h') document.getElementById('conv_f_m3h').value = parseFloat(m3h.toFixed(3));
        if(source !== 'lps') document.getElementById('conv_f_lps').value = parseFloat(lps.toFixed(3));
        if(source !== 'lpm') document.getElementById('conv_f_lpm').value = parseFloat(lpm.toFixed(3));
        if(source !== 'gpm') document.getElementById('conv_f_gpm').value = parseFloat(gpm.toFixed(3));
    }
    
    // Velocity Calc
    function calcVelocity() {
        const id_mm = parseFloat(document.getElementById('vel_id').value) || 0;
        const flow = parseFloat(document.getElementById('vel_flow').value) || 0;
        const unit = document.getElementById('vel_flow_unit').value;
        
        if(id_mm <= 0) return;
        
        let q_m3s = 0;
        if(unit === 'm3h') q_m3s = flow / 3600.0;
        if(unit === 'lps') q_m3s = flow / 1000.0;
        if(unit === 'lpm') q_m3s = flow / 60000.0;
        if(unit === 'gpm') q_m3s = flow / 15850.3;
        
        const area = Math.PI * Math.pow((id_mm/1000.0)/2, 2);
        
        if(area > 0) {
            const v_ms = q_m3s / area;
            const v_fs = v_ms * 3.28084;
            document.getElementById('vel_res_ms').innerText = v_ms.toFixed(2) + " m/s";
            document.getElementById('vel_res_fs').innerText = v_fs.toFixed(2) + " ft/s";
        }
    }

    // --- TOTAL HEAD CALCULATION (Card 16) ---
    function calculateTotalHead() {
        const suction = parseFloat(document.getElementById('th_suction').value) || 0;
        const sand = parseFloat(document.getElementById('th_sand').value) || 0;
        const hydro = parseFloat(document.getElementById('th_hydro').value) || 0;
        const disk = parseFloat(document.getElementById('th_disk').value) || 0;
        const venturi = parseFloat(document.getElementById('th_venturi').value) || 0;
        const fittings = parseFloat(document.getElementById('th_fittings').value) || 0;
        const mainInlet = parseFloat(document.getElementById('th_main_inlet').value) || 0;
        
        const total = suction + sand + hydro + disk + venturi + fittings + mainInlet;
        
        document.getElementById('th_total_result').value = total.toFixed(2);
    }
    
    // --- UNIFORMITY CALCULATION (Card 17 Auto) ---
    function calculateUniformity(pInlet, pEnd) {
        if(!pInlet || !pEnd || pInlet <= 0) return;
        
        const hf = pInlet - pEnd;
        
        // Populate Readonly fields in Card 17
        document.getElementById('uni_inlet_p').value = pInlet.toFixed(2);
        document.getElementById('uni_end_p').value = pEnd.toFixed(2);
        
        // Pressure Variation
        const pMax = pInlet;
        const pMin = pEnd;
        const pVar = ((pMax - pMin) / pMax) * 100;
        
        // Flow Variation Calc (Based on x = 0.5)
        const qVar = (1 - Math.pow((pMin / pMax), 0.5)) * 100;
        
        document.getElementById('uni_q_var').value = qVar.toFixed(1);

        const pAvg = pMin + (0.75 * hf);
        
        let eu = 0;
        if(pAvg > 0) {
            eu = 100 * (Math.pow(pMin, 0.5) / Math.pow(pAvg, 0.5));
        }
        
        document.getElementById('uni_var').innerText = pVar.toFixed(1) + "%";
        document.getElementById('uni_eu').innerText = eu.toFixed(1) + "%";
    }

