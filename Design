<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Integrated Drip Calculator</title>
    <style>
        :root { --text-secondary: #a0a0a0; --accent-color: #00e676; --output-bg: #d9ead3; }
        body { font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background-color: #f4f7f6; margin: 0; padding: 20px; min-height: 100vh; }
        
        /* Container for JS Masonry */
        .app-container {
            position: relative;
            width: 100%;
            margin: 0 auto;
        }

        .card {
            background: #fff;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            border: 1px solid #e1e1e1;
            
            /* Absolute positioning for JS Layout */
            position: absolute; 
            width: 350px; /* Fixed width for masonry calc */
            box-sizing: border-box;
            
            /* Initial state */
            top: 0;
            left: 0;
            transition: top 0.3s, left 0.3s;
        }

        /* Responsive Widths handled by JS, but max-width limits container */
        @media (max-width: 768px) {
            .card { width: 100%; position: relative; margin-bottom: 20px; }
            .app-container { display: block; }
        }

        .card-title { margin: 0 0 15px 0; font-size: 1.5rem; font-weight: bold; text-align: center; color: #333; border-bottom: 2px solid #e0e0e0; padding-bottom: 10px; }
        .card-badge { position: absolute; top: 10px; right: 10px; background: #e0e0e0; color: #555; font-size: 0.8rem; padding: 2px 8px; border-radius: 10px; font-weight: bold; }
        .input-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
        .control-group { display: flex; gap: 10px; margin-bottom: 15px; }
        .control-group > div { flex: 1; }
        label { display: block; margin-bottom: 5px; font-weight: 600; font-size: 0.9rem; color: #555; flex: 1; }
        .input-container { display: flex; align-items: center; width: 180px; }
        select, input { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 8px; font-size: 1rem; box-sizing: border-box; text-align: center; }
        select:focus, input:focus { border-color: #007bff; outline: none; }
        .highlight-input { background-color: #f0f8ff; border-color: #b0d4ff; }
        .unit { margin-left: 8px; font-size: 13px; color: #666; width: 40px; }
        .output-box { background-color: #eef2f5; color: #2c3e50; font-weight: bold; border: 1px solid #dde2e5; }
        .unit-select { width: 80px; margin-left: 5px; padding: 5px; font-size: 0.9rem; }
        .small-result { font-size: 12px; text-align: right; margin-top: 2px; color: #666; padding-right: 50px; }
        .centered-text { text-align: center; font-size: 0.9rem; color: #666; margin-top: 5px; }
        .results-section { background-color: #eef2f5; border-radius: 10px; padding: 15px; margin-top: 20px; }
        .result-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #dde2e5; }
        .result-row:last-child { border-bottom: none; }
        .result-label { color: #666; font-size: 0.95rem; }
        .result-value { font-weight: 700; color: #2c3e50; font-size: 1.1rem; }
        .result-value.highlight { color: #007bff; }
        h3 { display: none; }

        /* ===== BOX 19 STYLES ===== */
        #card-19 {
            width: calc(100% - 40px) !important;
        }
        .valve-table-wrapper { overflow-x: auto; margin-top: 10px; }
        .valve-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
        .valve-table th {
            background: #2c3e50;
            color: #fff;
            padding: 7px 5px;
            text-align: center;
            font-size: 0.75rem;
            white-space: nowrap;
        }
        .valve-table td {
            padding: 5px 4px;
            border: 1px solid #dde2e5;
            text-align: center;
            vertical-align: middle;
        }
        .valve-table tr:nth-child(even) td { background: #f8f9fa; }
        .valve-table input[type="number"], .valve-table input[type="text"], .valve-table select {
            width: 100%;
            min-width: 60px;
            padding: 4px 3px;
            font-size: 0.78rem;
            border: 1px solid #ccc;
            border-radius: 4px;
            text-align: center;
            box-sizing: border-box;
        }
        .valve-table .out-cell {
            background: #e8f5e9;
            font-weight: bold;
            color: #1b5e20;
            font-size: 0.82rem;
        }
        .valve-table .out-cell.warn { background: #fff3e0; color: #e65100; }
        .valve-row-label {
            background: #3498db !important;
            color: #fff !important;
            font-weight: bold;
            white-space: nowrap;
        }
        .box19-common { display: flex; gap: 15px; flex-wrap: wrap; margin-bottom: 12px; align-items: flex-end; }
        .box19-common > div { flex: 1; min-width: 120px; }
        .box19-common label { font-size: 0.85rem; margin-bottom: 3px; }
        .btn-add-valve {
            background: #28a745;
            color: #fff;
            border: none;
            padding: 8px 16px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: bold;
            margin-top: 10px;
        }
        .btn-add-valve:hover { background: #218838; }
        .btn-remove-valve {
            background: #dc3545;
            color: #fff;
            border: none;
            padding: 3px 8px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.75rem;
        }
        .summary-section {
            background: #f0f4f8;
            border-radius: 10px;
            padding: 15px;
            margin-top: 18px;
            border: 1px solid #cdd6e0;
        }
        .summary-section h4 {
            margin: 0 0 10px 0;
            color: #2c3e50;
            font-size: 1rem;
            border-bottom: 1px solid #cdd6e0;
            padding-bottom: 6px;
            display: block;
        }
        .summary-grid { display: flex; gap: 20px; flex-wrap: wrap; }
        .summary-col { flex: 1; min-width: 200px; }
        .summary-col h5 { margin: 0 0 6px 0; color: #555; font-size: 0.85rem; display: block; }
        .summary-item { display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px dashed #cdd6e0; font-size: 0.82rem; }
        .summary-item:last-child { border-bottom: none; }
        .summary-item .s-key { color: #555; }
        .summary-item .s-val { font-weight: bold; color: #1a237e; }
    </style>
</head>
<body>
<div class="app-container">

    <div class="card" id="card-1">
        <div class="card-badge">#1</div>
        <div class="card-title">1. Crop Factor (Kc)</div>
        <div class="input-row"><label>Category</label><div class="input-container"><select id="category" onchange="updateInterface()"><option value="vegetable">Vegetable / Field</option><option value="fruit">Fruit / Permanent</option></select></div><span class="unit"></span></div>
        <div class="input-row"><label>Crop</label><div class="input-container"><select id="crop" onchange="calculateKc()"></select></div><span class="unit"></span></div>
        <div class="input-row"><label>Stage</label><div class="input-container"><select id="stage" onchange="calculateKc()"></select></div><span class="unit"></span></div>
        <div class="input-row"><label style="font-weight:bold;">Kc Result</label><div class="input-container"><input type="text" id="kc_result" class="output-box" readonly></div><span class="unit"></span></div>
    </div>

    <div class="card" id="card-2">
        <div class="card-badge">#2</div>
        <div class="card-title">2. Water Needed</div>
        <div class="input-row"><label>Crop Area</label><div class="input-container"><input type="number" step="any" id="area" value="0.18" oninput="calculateVolume()"></div><span class="unit">m²</span></div>
        <div class="input-row"><label>Pan Evaporation</label><div class="input-container"><input type="number" step="any" id="pan_evap" value="8" oninput="calculateVolume()"></div><span class="unit">mm</span></div>
        <div class="input-row"><label>Pan Coefficient</label><div class="input-container"><input type="number" step="any" id="pan_coeff" value="0.7" oninput="calculateVolume()"></div><span class="unit"></span></div>
        <div class="input-row"><label>Crop Coeff (Kc)</label><div class="input-container"><input type="number" step="any" id="crop_coeff" value="0.8" oninput="calculateVolume()"></div><span class="unit"></span></div>
        <div class="input-row"><label>% Wetted Area</label><div class="input-container"><input type="number" step="any" id="wetted_area" value="75" oninput="calculateVolume()"></div><span class="unit">%</span></div>
        <hr style="border: 0; border-top: 1px solid #eee; margin: 15px 0;">
        <div class="input-row"><label style="font-weight:bold; color: #28a745;">Required Volume</label><div class="input-container"><input type="text" id="final_volume" class="output-box" readonly></div><span class="unit">L/Day</span></div>
        <div class="small-result" id="mm_result">3.51 mm</div>
    </div>

    <div class="card" id="card-3">
        <div class="card-badge">#3</div>
        <div class="card-title">3. Total System Flow</div>
        
        <div class="control-group" style="background-color: #f9f9f9; padding: 10px; border-radius: 8px; margin-bottom: 10px;">
            <div><label style="font-size:0.85rem; color:#007bff;">L (m)</label><input type="number" id="field_len" placeholder="Length" oninput="calculateAreaFromDim()"></div>
            <div><label style="font-size:0.85rem; color:#007bff;">W (m)</label><input type="number" id="field_wid" placeholder="Width" oninput="calculateAreaFromDim()"></div>
        </div>
        <div class="input-row"><label>Total Area</label><div class="input-container"><input type="number" step="any" id="field_area" value="3600" oninput="calculateSystemFlow()"></div><span class="unit">m²</span></div>
        <div class="input-row"><label>Bed Spacing</label><div class="input-container"><input type="number" step="any" id="bed_spacing" value="2" oninput="calculateSystemFlow()"></div><span class="unit">m</span></div>
        <div class="input-row"><label>No. of Laterals</label><div class="input-container"><input type="number" step="any" id="laterals_per_bed" value="2" oninput="calculateSystemFlow()"></div><span class="unit">Nos</span></div>
        <div class="input-row"><label>Dripper Spacing</label><div class="input-container"><input type="number" step="any" id="dripper_spacing" value="0.3" oninput="calculateSystemFlow()"></div><span class="unit">m</span></div>
        <div class="input-row"><label>Dripper Discharge</label><div class="input-container"><input type="number" step="any" id="dripper_discharge" value="2" oninput="calculateSystemFlow()"></div><span class="unit">L/hr</span></div>
        <hr style="border: 0; border-top: 1px solid #eee; margin: 15px 0;">
        <div class="input-row"><label>Total Lateral Length</label><div class="input-container"><div id="total_lateral_length" style="color: #666; width: 100%; text-align: center;">2500 m</div></div><span class="unit"></span></div>
        <div class="input-row"><label style="font-weight:bold;">Total Drippers</label><div class="input-container"><input type="text" id="total_drippers" class="output-box" readonly></div><span class="unit">Qty</span></div>
        <div class="input-row"><label style="font-weight:bold; color: #28a745;">Total Flow</label><div class="input-container" style="width: 250px;"><input type="text" id="total_flow" class="output-box" readonly style="width: 60%;"><select id="flow_unit" class="unit-select" onchange="calculateSystemFlow()"><option value="m3h">m³/hr</option><option value="lph">LPH</option><option value="lpm">LPM</option><option value="lps">LPS</option></select></div><span class="unit"></span></div>
    </div>

    <div class="card" id="card-4">
        <div class="card-badge">#4</div>
        <div class="card-title">4. Available Pump Flow</div>
        <div class="input-row"><label>Pump HP</label><div class="input-container"><input type="number" step="any" id="pump_hp_input" value="5" oninput="calculateAvailableFlow()"></div><span class="unit">HP</span></div>
        <div class="input-row"><label>Total Head</label><div class="input-container"><input type="number" step="any" id="pump_head_input" value="45" oninput="calculateAvailableFlow()"></div><span class="unit">m</span></div>
        <div class="input-row"><label>Efficiency</label><div class="input-container"><input type="number" step="any" id="pump_eff_input" value="60" oninput="calculateAvailableFlow()"></div><span class="unit">%</span></div>
        <hr style="border: 0; border-top: 1px solid #eee; margin: 15px 0;">
        <div class="input-row"><label style="font-weight:bold; color: #28a745;">Flow (LPS)</label><div class="input-container"><input type="text" id="avail_flow_lps" class="output-box" readonly></div><span class="unit">lps</span></div>
        <div class="input-row"><label style="font-weight:bold; color: #28a745;">Flow (m³/hr)</label><div class="input-container"><input type="text" id="avail_flow_m3h" class="output-box" readonly></div><span class="unit">m³/hr</span></div>
    </div>

    <div class="card" id="card-5">
        <div class="card-badge">#5</div>
        <div class="card-title">5. Pump HP Required</div>
        <div class="input-row"><label>Required Flow</label><div class="input-container"><input type="number" step="any" id="req_flow" value="18.00" oninput="calculateRequiredHP()"></div><span class="unit">m³/hr</span></div>
        <div class="input-row"><label>Total Head</label><div class="input-container"><input type="number" step="any" id="req_head" value="45" oninput="calculateRequiredHP()"></div><span class="unit">m</span></div>
        <div class="input-row"><label>Efficiency</label><div class="input-container"><input type="number" step="any" id="req_eff" value="60" oninput="calculateRequiredHP()"></div><span class="unit">%</span></div>
        <hr style="border: 0; border-top: 1px solid #eee; margin: 15px 0;">
        <div class="input-row" style="justify-content: flex-end;"><div style="text-align:right; font-size:12px; margin-bottom:5px; color:#666;">Required: <span id="calc_hp_val" style="font-weight:bold; color:#000;">2.22</span> HP</div></div>
        <div class="input-row"><label style="font-weight:bold; color:#28a745;">Standard Pump</label><div class="input-container"><input type="text" id="final_hp" class="output-box" readonly></div><span class="unit">HP</span></div>
        <div class="centered-text"><span id="final_kw">2 kW</span></div>
    </div>

    <div class="card" id="card-6">
        <div class="card-badge">#6</div>
        <div class="card-title">6. Lateral Design</div>
        <div class="control-group"><div><label>Lateral Size</label><select class="nominal-dia" onchange="updateID(this)"><option value="12">12 mm</option><option value="16" selected>16 mm</option><option value="20">20 mm</option><option value="custom">Custom</option></select></div><div><label>Class</label><select class="pipe-class" onchange="updateID(this)"><option value="1">Class 1</option><option value="2" selected>Class 2</option><option value="3">Class 3</option></select></div></div>
        <div class="control-group"><div><label>Inner ID (mm)</label><input type="number" class="id-mm highlight-input" step="0.1" oninput="calculate(this)"></div><div><label>Length (m)</label><input type="number" class="length-m" value="69" oninput="calculate(this)"></div></div>
        <div class="control-group"><div><label>Spacing (m)</label><input type="number" class="spacing-m" value="0.3" step="0.01" oninput="calculate(this)"></div><div><label>Dripper Q (lph)</label><input type="number" class="discharge-lph" value="2.0" step="0.1" oninput="calculate(this)"></div></div>
        
        <div class="control-group">
            <div><label style="font-size:0.85rem;">Drip/Plant</label><input type="number" class="drippers-per-plant" value="1" oninput="calculate(this)"></div>
            <div><label style="font-size:0.85rem;">Roughness</label><input type="number" class="roughness" value="140" oninput="calculate(this)"></div>
        </div>
        <div class="control-group">
            <div><label style="font-size:0.85rem;">Outlet Factor</label><input type="number" class="outlet-factor" value="0.4" step="0.01" oninput="calculate(this)"></div>
            <div><label>Pressure (End)</label><input type="number" class="pressure-m" id="lat_pressure_input" value="10.0" oninput="calculate(this)"></div>
        </div>

        <div class="control-group"><div><label>Total Q Unit</label><select class="flow-unit" onchange="calculate(this)"><option value="lph">lph</option><option value="m3hr">m³/hr</option><option value="lps">lps</option><option value="lpm">lpm</option><option value="gpm">gpm (US)</option></select></div><div><label>Velocity Unit</label><select class="velocity-unit" onchange="calculate(this)"><option value="m/s">m/s</option><option value="ft/s">ft/s</option></select></div></div>
        
        <div class="results-section">
            <div class="result-row"><span class="result-label">Number of Drippers</span><span class="result-value res-drippers">-</span></div>
            <div class="result-row"><span class="result-label">Total Flow (Q)</span><span class="result-value res-discharge">-</span></div>
            <div class="result-row"><span class="result-label">Velocity (V)</span><span class="result-value highlight res-velocity">-</span></div>
            <div class="result-row"><span class="result-label">Head Loss (Hf)</span><span class="result-value highlight res-headloss" id="lat_res_headloss">-</span></div>
            <div class="result-row"><span class="result-label">Inlet Pressure</span><span class="result-value res-pressure" id="lat_res_pressure">-</span></div>
        </div>
    </div>

    <div class="card" id="card-7">
        <div class="card-badge">#7</div>
        <div class="card-title">7. Submain Head Loss</div>
        <div class="input-row"><label>Type of Pipe</label><div class="input-container"><select id="sub_type" onchange="updateSubmainOptions()"><option value="agri">Agri PVC (IS 4985)</option><option value="upvc">uPVC (ASTM)</option><option value="hdpe">HDPE (PE 100)</option></select></div><span class="unit"></span></div>
        <div class="input-row"><label>Pressure Rating</label><div class="input-container"><select id="sub_class" onchange="updateSubmainSizeList()"></select></div><span class="unit"></span></div>
        <div class="input-row"><label>Pipe Size</label><div class="input-container"><select id="sub_size" onchange="updateSubmainID()"></select></div><span class="unit"></span></div>
        <div class="input-row"><label>Inside Dia (ID)</label><div class="input-container"><input type="number" id="sub_id" class="highlight-input" step="0.1" oninput="calculateSubmain()"></div><span class="unit">mm</span></div>
        <div class="input-row"><label>Length</label><div class="input-container"><input type="number" id="sub_length" value="50" oninput="calculateSubmain()"></div><span class="unit">m</span></div>
        <div class="input-row"><label>Flow Rate</label><div class="input-container" style="width: 250px;"><input type="number" id="sub_flow" value="3.33" step="0.01" oninput="calculateSubmain()" style="width: 60%;"><select id="sub_flow_unit" class="unit-select" onchange="calculateSubmain()"><option value="lps">LPS</option><option value="lpm">LPM</option><option value="m3h">m³/hr</option></select></div><span class="unit"></span></div>
        <div class="input-row"><label>Roughness (C)</label><div class="input-container"><input type="number" id="sub_roughness" value="150" oninput="calculateSubmain()"></div><span class="unit"></span></div>
        <div class="input-row"><label>Outlet Factor</label><div class="input-container"><input type="number" id="sub_outlet_factor" value="0.36" step="0.01" oninput="calculateSubmain()"></div><span class="unit"></span></div>
        <div class="input-row"><label>Lat. Inlet Press.</label><div class="input-container"><input type="number" id="lat_inlet_press" value="10" oninput="calculateSubmain()" placeholder="Optional"></div><span class="unit">m</span></div>
        <hr style="border: 0; border-top: 1px solid #eee; margin: 15px 0;">
        <div class="results-section">
            <div class="result-row"><span class="result-label">Velocity</span><span class="result-value" id="sub_velocity">-</span></div>
            <div class="result-row"><span class="result-label">Head Loss</span><span class="result-value highlight" id="sub_head_loss">-</span></div>
            <div class="result-row"><span class="result-label">Inlet Pressure</span><span class="result-value" id="sub_total_pressure">-</span></div>
        </div>
    </div>

    <div class="card" id="card-8">
        <div class="card-badge">#8</div>
        <div class="card-title">8. Mainline Head Loss</div>
        <div class="input-row"><label>Type of Pipe</label><div class="input-container"><select id="main_type" onchange="updateMainOptions()"><option value="agri">Agri PVC (IS 4985)</option><option value="upvc">uPVC (ASTM)</option><option value="hdpe">HDPE (PE 100)</option></select></div><span class="unit"></span></div>
        <div class="input-row"><label>Pressure Rating</label><div class="input-container"><select id="main_class" onchange="updateMainSizeList()"></select></div><span class="unit"></span></div>
        <div class="input-row"><label>Pipe Size</label><div class="input-container"><select id="main_size" onchange="updateMainID()"></select></div><span class="unit"></span></div>
        <div class="input-row"><label>Inside Dia (ID)</label><div class="input-container"><input type="number" id="main_id" class="highlight-input" step="0.1" oninput="calculateMainline()"></div><span class="unit">mm</span></div>
        <div class="input-row"><label>Length</label><div class="input-container"><input type="number" id="main_length" value="100" oninput="calculateMainline()"></div><span class="unit">m</span></div>
        <div class="input-row"><label>Flow Rate</label><div class="input-container" style="width: 250px;"><input type="number" id="main_flow" value="3.87" step="0.01" oninput="calculateMainline()" style="width: 60%;"><select id="main_flow_unit" class="unit-select" onchange="calculateMainline()"><option value="lps">LPS</option><option value="lpm">LPM</option><option value="m3h">m³/hr</option></select></div><span class="unit"></span></div>
        <div class="input-row"><label>Roughness (C)</label><div class="input-container"><input type="number" id="main_roughness" value="150" oninput="calculateMainline()"></div><span class="unit"></span></div>
        <div class="input-row"><label>Submain Inlet P.</label><div class="input-container"><input type="number" id="sub_inlet_press_link" value="10" oninput="calculateMainline()" placeholder="Auto"></div><span class="unit">m</span></div>
        <hr style="border: 0; border-top: 1px solid #eee; margin: 15px 0;">
        <div class="results-section">
            <div class="result-row"><span class="result-label">Velocity</span><span class="result-value" id="main_velocity">-</span></div>
            <div class="result-row"><span class="result-label">Head Loss</span><span class="result-value highlight" id="main_head_loss">-</span></div>
            <div class="result-row"><span class="result-label">Inlet Pressure</span><span class="result-value" id="main_total_pressure">-</span></div>
        </div>
    </div>

    <div class="card" id="card-9">
        <div class="card-badge">#9</div>
        <div class="card-title">9. Time of Irrigation</div>
        <div class="input-row"><label style="color: #666; font-size: 0.85rem;">Bed Spacing (m)</label><div class="input-container"><input type="text" id="pr_bed_spacing" class="output-box" readonly></div></div>
        <div class="input-row"><label style="color: #666; font-size: 0.85rem;">Dripper Spacing (m)</label><div class="input-container"><input type="text" id="pr_drip_spacing" class="output-box" readonly></div></div>
        <div class="input-row"><label style="color: #666; font-size: 0.85rem;">Laterals / Bed</label><div class="input-container"><input type="text" id="pr_lat_per_bed" class="output-box" readonly></div></div>
